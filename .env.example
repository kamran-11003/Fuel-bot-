# ──────────────────────────────────────────────────────────
# Fuel Complaint Bot — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────

# Server
PORT=3000

# Redis (ioredis)
# Local:   redis://127.0.0.1:6379
# Cloud:   redis://:<password>@<host>:<port>
REDIS_URL=redis://127.0.0.1:6379

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WEBHOOK_VERIFY_TOKEN=your-custom-verify-token

# Display number shown on landing page (country code, no + or spaces)
# e.g. 923001234567 for +92 300 1234567
WHATSAPP_DISPLAY_NUMBER=92xxxxxxxxxx

# Government API endpoint (complaint dispatch)
GOVT_API_URL=https://your-govt-api.example.com/complaints
