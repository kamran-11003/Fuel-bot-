# Server
PORT=3000

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WEBHOOK_VERIFY_TOKEN=your-custom-verify-token

# The WhatsApp number citizens message (country code, no + or spaces)
# e.g. 923001234567 for +92 300 1234567
# Used on the landing page for the "Message on WhatsApp" button
WHATSAPP_DISPLAY_NUMBER=92xxxxxxxxxx

# Optional: URL to POST complaints to when submitted (placeholder API)
# Leave blank to only log to console
COMPLAINT_API_URL=
